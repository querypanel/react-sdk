# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase
SUPABASE_EDGE_URL=

# OpenAI API Credentials
OPENAI_PROJECT_ID=
OPENAI_API_KEY=

SQL_AGENT_URL=
# Preferred for querypanel-sdk / Mastra server-to-server auth.
SERVICE_API_KEY=
# Legacy fallback for older setups. If set, it must match SERVICE_API_KEY on querypanel-sdk.
SQL_AGENT_API_KEY=
